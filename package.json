  },
  "description": "Bring your models. We'll bring the party.",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://llm-party.party",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aalasolutions/llm-party.git"
  },
  "bugs": {
